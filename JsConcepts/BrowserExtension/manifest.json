{
    "manifest_version": 3,
    "name": "Extension Demo",
    "version": "1.0",
    "description": "Monitors text input for sensitive data exfiltration.",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "./index.js"
            ]
        }
    ]
}